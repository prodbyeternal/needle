{
  "name": "needle",
  "version": "1.0.0",
  "description": "Futuristic tactile digital-physical vinyl record player simulator.",
  "main": "main.js",
  "productName": "NEEDLE",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux AppImage deb",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis"
  },
  "keywords": [
    "vinyl",
    "record-player",
    "electron",
    "web-audio-api",
    "tactile",
    "music-player"
  ],
  "author": "eternal",
  "license": "MIT",
  "build": {
    "appId": "com.prodbyeternal.needle",
    "productName": "NEEDLE",
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "renderer/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "win": {
      "icon": "assets/icons/needle.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-windows-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NEEDLE"
    },
    "mac": {
      "artifactName": "${productName}-${version}-macos-${arch}.${ext}",
      "category": "public.app-category.music",
      "icon": "assets/icons/needle.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "AudioVideo",
      "icon": "assets/icons/needle.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "maintainer": "prodbyeternal"
    }
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^26.8.1"
  }
}
